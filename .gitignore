rag_corpus/**/*.pdf
rag_corpus/**/*.txt

# ── Vector store — rebuilt by build_vector_store.py ──────────────────────────
vector_store/

# ── HuggingFace model cache — auto-downloaded on first run ───────────────────
.cache/
models/

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user

# ── LangGraph checkpoints (SQLite) ───────────────────────────────────────────
*.db
*.sqlite
checkpoints/

# ── Test outputs ─────────────────────────────────────────────────────────────
outputs/
results/