# ── Environment & secrets ────────────────────────────────────────────────────
.env
.env.*
*.key

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── RAG corpus — PDFs are large and freely re-downloadable ───────────────────
